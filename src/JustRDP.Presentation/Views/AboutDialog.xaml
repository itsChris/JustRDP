<Window x:Class="JustRDP.Presentation.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="About JustRDP"
        Height="360" Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- App name + version -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <TextBlock Text="JustRDP" FontSize="28" FontWeight="Bold"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="VersionText" FontSize="13" Opacity="0.6"
                       HorizontalAlignment="Center" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Made with love -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,16,0,16">
            <TextBlock Text="Made with" VerticalAlignment="Center" FontSize="14" Opacity="0.7" />
            <materialDesign:PackIcon Kind="Heart" Width="18" Height="18"
                                     Foreground="#E53935" Margin="6,0"
                                     VerticalAlignment="Center" />
            <TextBlock Text="in Switzerland" VerticalAlignment="Center" FontSize="14" Opacity="0.7" />
        </StackPanel>

        <!-- Company info -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,8">
            <TextBlock Text="Solvia AG" FontSize="16" FontWeight="Medium"
                       HorizontalAlignment="Center" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <materialDesign:PackIcon Kind="Email" Width="16" Height="16"
                                         VerticalAlignment="Center" Opacity="0.6" Margin="0,0,6,0" />
                <TextBlock>
                    <Hyperlink x:Name="EmailLink" Click="EmailLink_Click">info@solvia.ch</Hyperlink>
                </TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                <materialDesign:PackIcon Kind="Phone" Width="16" Height="16"
                                         VerticalAlignment="Center" Opacity="0.6" Margin="0,0,6,0" />
                <TextBlock Text="+41 44 885 00 10" FontSize="13" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                <materialDesign:PackIcon Kind="Web" Width="16" Height="16"
                                         VerticalAlignment="Center" Opacity="0.6" Margin="0,0,6,0" />
                <TextBlock>
                    <Hyperlink x:Name="WebLink" Click="WebLink_Click">www.solvia.ch</Hyperlink>
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <!-- Close button -->
        <Button Grid.Row="4" Content="Close" IsCancel="True" Click="CloseButton_Click"
                Style="{StaticResource MaterialDesignFlatButton}"
                HorizontalAlignment="Center" MinWidth="100" />
    </Grid>
</Window>
