<UserControl x:Class="JustRDP.Presentation.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:JustRDP.Presentation.ViewModels"
             xmlns:converters="clr-namespace:JustRDP.Presentation.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}">

    <UserControl.Resources>
        <converters:RelativeTimeConverter x:Key="RelativeTime" />
        <converters:AvailabilityStatusToBrushConverter x:Key="AvailabilityToBrush" />
        <converters:ConnectionTypeToIconConverter x:Key="ConnectionTypeToIcon" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:BoolToVisibilityConverter x:Key="InverseBoolToVis" Invert="True" />

        <!-- Shared DataGrid style -->
        <Style x:Key="DashboardDataGrid" TargetType="DataGrid" BasedOn="{StaticResource MaterialDesignDataGrid}">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="RowHeight" Value="36" />
            <Setter Property="ColumnHeaderHeight" Value="36" />
        </Style>

        <!-- Row style with subtle hover -->
        <Style x:Key="DashboardDataGridRow" TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- Section header style -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity" Value="0.8" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Loading state -->
        <ProgressBar IsIndeterminate="True" VerticalAlignment="Top"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

        <!-- Empty state -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVis}}">
            <materialDesign:PackIcon Kind="MonitorDashboard" Width="48" Height="48"
                                     HorizontalAlignment="Center" Opacity="0.25" Margin="0,0,0,16" />
            <TextBlock Text="No connections yet" FontSize="18" FontWeight="Medium"
                       TextAlignment="Center" Opacity="0.5" Margin="0,0,0,6" />
            <TextBlock Text="Create a connection from the toolbar or right-click the tree to get started."
                       TextWrapping="Wrap" Opacity="0.3" FontSize="13"
                       TextAlignment="Center" MaxWidth="340" />
        </StackPanel>

        <!-- Dashboard content -->
        <DockPanel Visibility="{Binding HasConnections, Converter={StaticResource BoolToVis}}">

            <!-- Stats bar (pinned top, not scrollable) -->
            <Border DockPanel.Dock="Top"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                    Padding="24,20,24,12">
                <WrapPanel HorizontalAlignment="Left">
                    <!-- Total -->
                    <materialDesign:Card Padding="20,14" Margin="0,0,12,8" MinWidth="120"
                                         materialDesign:ElevationAssist.Elevation="Dp1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Opacity="0.5" Margin="0,0,0,4">
                                <materialDesign:PackIcon Kind="ChartBox" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Total" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="{Binding TotalConnections}" FontSize="28" FontWeight="Medium" />
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Online -->
                    <materialDesign:Card Padding="20,14" Margin="0,0,12,8" MinWidth="120"
                                         materialDesign:ElevationAssist.Elevation="Dp1"
                                         Visibility="{Binding IsMonitoringEnabled, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <materialDesign:PackIcon Kind="CheckCircle" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#4CAF50" />
                                <TextBlock Text="Online" FontSize="12" VerticalAlignment="Center" Foreground="#4CAF50" />
                            </StackPanel>
                            <TextBlock Text="{Binding OnlineCount}" FontSize="28" FontWeight="Medium" Foreground="#4CAF50" />
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Offline -->
                    <materialDesign:Card Padding="20,14" Margin="0,0,12,8" MinWidth="120"
                                         materialDesign:ElevationAssist.Elevation="Dp1"
                                         Visibility="{Binding IsMonitoringEnabled, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <materialDesign:PackIcon Kind="CloseCircle" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#F44336" />
                                <TextBlock Text="Offline" FontSize="12" VerticalAlignment="Center" Foreground="#F44336" />
                            </StackPanel>
                            <TextBlock Text="{Binding OfflineCount}" FontSize="28" FontWeight="Medium" Foreground="#F44336" />
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Open Sessions -->
                    <materialDesign:Card Padding="20,14" Margin="0,0,12,8" MinWidth="120"
                                         materialDesign:ElevationAssist.Elevation="Dp1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Opacity="0.5" Margin="0,0,0,4">
                                <materialDesign:PackIcon Kind="PowerPlug" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Sessions" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="{Binding OpenSessions}" FontSize="28" FontWeight="Medium" />
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- RDP -->
                    <materialDesign:Card Padding="20,14" Margin="0,0,12,8" MinWidth="100"
                                         materialDesign:ElevationAssist.Elevation="Dp1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Opacity="0.5" Margin="0,0,0,4">
                                <materialDesign:PackIcon Kind="MonitorDashboard" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="RDP" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="{Binding RdpCount}" FontSize="28" FontWeight="Medium" />
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- SSH -->
                    <materialDesign:Card Padding="20,14" Margin="0,0,0,8" MinWidth="100"
                                         materialDesign:ElevationAssist.Elevation="Dp1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Opacity="0.5" Margin="0,0,0,4">
                                <materialDesign:PackIcon Kind="Console" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="SSH" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="{Binding SshCount}" FontSize="28" FontWeight="Medium" />
                        </StackPanel>
                    </materialDesign:Card>
                </WrapPanel>
            </Border>

            <!-- Recent Connections (pinned, max 10 rows so doesn't need its own scroll) -->
            <StackPanel DockPanel.Dock="Top" Margin="24,16,24,0">
                <TextBlock Text="Recent Connections" Style="{StaticResource SectionHeader}" />

                <TextBlock Text="No recent connections yet. Open a connection to see it here."
                           Opacity="0.3" FontSize="13" Margin="0,0,0,12"
                           Visibility="{Binding HasRecentConnections, Converter={StaticResource InverseBoolToVis}}" />

                <DataGrid ItemsSource="{Binding RecentConnections}"
                          Style="{StaticResource DashboardDataGrid}"
                          RowStyle="{StaticResource DashboardDataGridRow}"
                          MaxHeight="400"
                          MouseDoubleClick="DataGrid_MouseDoubleClick"
                          Margin="0,0,0,12"
                          Visibility="{Binding HasRecentConnections, Converter={StaticResource BoolToVis}}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Name" Width="2*" SortMemberPath="Name">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                                                 Fill="{Binding Status, Converter={StaticResource AvailabilityToBrush}}" />
                                        <materialDesign:PackIcon Width="16" Height="16" Margin="0,0,6,0"
                                                                 VerticalAlignment="Center" Opacity="0.7"
                                                                 Kind="{Binding ConnectionType, Converter={StaticResource ConnectionTypeToIcon}}" />
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Host" Binding="{Binding Host}" Width="2*" />
                        <DataGridTextColumn Header="Protocol" Binding="{Binding Protocol}" Width="80" />
                        <DataGridTextColumn Header="Last Connected" Binding="{Binding LastConnectedAt, Converter={StaticResource RelativeTime}}" Width="140" />
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <!-- Separator -->
            <Separator DockPanel.Dock="Top" Margin="24,0" Opacity="0.3" />

            <!-- All Connections header + filter (pinned) -->
            <DockPanel DockPanel.Dock="Top" Margin="24,12,24,10">
                <TextBlock Text="All Connections" Style="{StaticResource SectionHeader}"
                           DockPanel.Dock="Left" Margin="0" VerticalAlignment="Center" />
                <TextBox Text="{Binding ConnectionFilterText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Filter..."
                         materialDesign:HintAssist.IsFloating="False"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                         FontSize="13" Padding="8,4"
                         Width="220" HorizontalAlignment="Right" VerticalAlignment="Center" />
            </DockPanel>

            <!-- All Connections DataGrid (fills remaining space, scrolls internally) -->
            <DataGrid ItemsSource="{Binding AllConnections}"
                      Style="{StaticResource DashboardDataGrid}"
                      RowStyle="{StaticResource DashboardDataGridRow}"
                      CanUserSortColumns="True"
                      Margin="24,0,24,24"
                      MouseDoubleClick="DataGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Name" Width="2*" SortMemberPath="Name" SortDirection="Ascending">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                                             Fill="{Binding Status, Converter={StaticResource AvailabilityToBrush}}" />
                                    <materialDesign:PackIcon Width="16" Height="16" Margin="0,0,6,0"
                                                             VerticalAlignment="Center" Opacity="0.7"
                                                             Kind="{Binding ConnectionType, Converter={StaticResource ConnectionTypeToIcon}}" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Host" Binding="{Binding Host}" Width="2*" />
                    <DataGridTextColumn Header="Protocol" Binding="{Binding Protocol}" Width="80" />
                    <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="70" />
                    <DataGridTextColumn Header="Last Connected" Binding="{Binding LastConnectedAt, Converter={StaticResource RelativeTime}}" Width="140" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</UserControl>
