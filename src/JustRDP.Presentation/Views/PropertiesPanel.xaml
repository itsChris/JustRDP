<UserControl x:Class="JustRDP.Presentation.Views.PropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:JustRDP.Presentation.ViewModels"
             xmlns:converters="clr-namespace:JustRDP.Presentation.Converters"
             d:DataContext="{d:DesignInstance vm:PropertiesViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:RelativeTimeConverter x:Key="RelativeTime" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
        <StackPanel Visibility="{Binding HasEntry, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Properties" FontSize="16" FontWeight="Medium" Margin="0,0,0,12" />

            <!-- Name -->
            <TextBlock Text="Name" Opacity="0.6" FontSize="11" />
            <TextBlock Text="{Binding Name}" FontSize="14" Margin="0,0,0,12" TextWrapping="Wrap" />

            <!-- Type -->
            <TextBlock Text="Type" Opacity="0.6" FontSize="11" />
            <TextBlock Text="{Binding EntryType}" FontSize="14" Margin="0,0,0,12" />

            <!-- Connection-specific fields -->
            <StackPanel Visibility="{Binding IsConnection, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Host" Opacity="0.6" FontSize="11" />
                <TextBlock Text="{Binding HostName}" FontSize="14" Margin="0,0,0,12" TextWrapping="Wrap" />

                <TextBlock Text="Port" Opacity="0.6" FontSize="11" />
                <TextBlock Text="{Binding Port}" FontSize="14" Margin="0,0,0,12" />
            </StackPanel>

            <!-- Credentials -->
            <TextBlock Text="Credentials" Opacity="0.6" FontSize="11" />
            <TextBlock Text="{Binding CredentialDisplay}" FontSize="14" Margin="0,0,0,12" TextWrapping="Wrap" />

            <!-- Usage tracking -->
            <StackPanel Visibility="{Binding IsConnection, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Last connected" Opacity="0.6" FontSize="11" />
                <TextBlock Text="{Binding LastConnected, Converter={StaticResource RelativeTime}}" FontSize="14" Margin="0,0,0,12" />

                <TextBlock Text="Times connected" Opacity="0.6" FontSize="11" />
                <TextBlock Text="{Binding TimesConnected}" FontSize="14" Margin="0,0,0,12" />
            </StackPanel>

            <!-- Notes -->
            <StackPanel Visibility="{Binding IsConnection, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Notes" Opacity="0.6" FontSize="11" />
                <TextBlock Text="{Binding Notes, TargetNullValue='—'}" FontSize="13" Margin="0,0,0,12"
                           TextWrapping="Wrap" Opacity="0.8" />
            </StackPanel>

            <!-- Edit Button -->
            <Button Content="Properties..."
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    HorizontalAlignment="Left" Margin="0,8,0,0"
                    Command="{Binding DataContext.OpenPropertiesDialogCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
