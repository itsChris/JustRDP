<Window x:Class="JustRDP.Presentation.Views.PropertiesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:JustRDP.Presentation.ViewModels"
        xmlns:converters="clr-namespace:JustRDP.Presentation.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="520" Width="680"
        MinHeight="420" MinWidth="580"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        d:DataContext="{d:DesignInstance vm:ConnectionPropertiesViewModel}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:BoolToVisibilityConverter x:Key="InverseBoolToVis" Invert="True" />
        <converters:IndexToVisibilityConverter x:Key="IndexToVisibility" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Main content area -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Navigation panel -->
            <Border Grid.Column="0"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}">
                <ListBox x:Name="NavList"
                         SelectedIndex="0"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="0,8">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                            <Setter Property="Padding" Value="16,10" />
                            <Setter Property="FontSize" Value="13" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CogOutline" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20" />
                            <TextBlock Text="General" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="KeyOutline" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20" />
                            <TextBlock Text="Credentials" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Visibility="{Binding IsFolder, Converter={StaticResource InverseBoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Monitor" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20" />
                            <TextBlock Text="Display" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Visibility="{Binding IsFolder, Converter={StaticResource InverseBoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="SwapHorizontal" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20" />
                            <TextBlock Text="Redirection" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Visibility="{Binding IsFolder, Converter={StaticResource InverseBoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="LanConnect" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20" />
                            <TextBlock Text="Connection" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Visibility="{Binding IsFolder, Converter={StaticResource InverseBoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="NoteTextOutline" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20" />
                            <TextBlock Text="Notes" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </Border>

            <!-- Content pages -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="24,16">
                    <!-- General -->
                    <StackPanel Visibility="{Binding SelectedIndex, ElementName=NavList, Converter={StaticResource IndexToVisibility}, ConverterParameter=0}">
                        <TextBlock Text="General" FontSize="18" FontWeight="Medium" Margin="0,0,0,20" />

                        <TextBox materialDesign:HintAssist.Hint="Name"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,16" />

                        <StackPanel Visibility="{Binding IsFolder, Converter={StaticResource InverseBoolToVis}}">
                            <TextBox materialDesign:HintAssist.Hint="Host Name"
                                     Text="{Binding HostName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,0,16" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="1"
                                         materialDesign:HintAssist.Hint="Port"
                                         Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <!-- Credentials -->
                    <StackPanel Visibility="{Binding SelectedIndex, ElementName=NavList, Converter={StaticResource IndexToVisibility}, ConverterParameter=1}">
                        <TextBlock Text="Credentials" FontSize="18" FontWeight="Medium" Margin="0,0,0,20" />

                        <TextBox materialDesign:HintAssist.Hint="Username"
                                 Text="{Binding CredentialUsername, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,16" />

                        <TextBox materialDesign:HintAssist.Hint="Domain"
                                 Text="{Binding CredentialDomain, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,16" />

                        <PasswordBox materialDesign:HintAssist.Hint="Password"
                                     materialDesign:PasswordBoxAssist.Password="{Binding CredentialPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                     Margin="0,0,0,8" />

                        <TextBlock Text="Leave empty to inherit credentials from parent folder."
                                   Opacity="0.5" FontSize="12" Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- Display -->
                    <StackPanel Visibility="{Binding SelectedIndex, ElementName=NavList, Converter={StaticResource IndexToVisibility}, ConverterParameter=2}">
                        <TextBlock Text="Display" FontSize="18" FontWeight="Medium" Margin="0,0,0,20" />

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     materialDesign:HintAssist.Hint="Width (0 = auto)"
                                     Text="{Binding DesktopWidth, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                            <TextBox Grid.Column="2"
                                     materialDesign:HintAssist.Hint="Height (0 = auto)"
                                     Text="{Binding DesktopHeight, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        </Grid>

                        <ComboBox materialDesign:HintAssist.Hint="Color Depth"
                                  SelectedValue="{Binding ColorDepth}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  Margin="0,0,0,16">
                            <ComboBoxItem Content="15-bit" Tag="15" />
                            <ComboBoxItem Content="16-bit" Tag="16" />
                            <ComboBoxItem Content="24-bit" Tag="24" />
                            <ComboBoxItem Content="32-bit" Tag="32" IsSelected="True" />
                        </ComboBox>

                        <ComboBox materialDesign:HintAssist.Hint="Resize Behavior"
                                  SelectedIndex="{Binding ResizeBehavior}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                    </StackPanel>

                    <!-- Redirection -->
                    <StackPanel Visibility="{Binding SelectedIndex, ElementName=NavList, Converter={StaticResource IndexToVisibility}, ConverterParameter=3}">
                        <TextBlock Text="Redirection" FontSize="18" FontWeight="Medium" Margin="0,0,0,20" />

                        <TextBlock Text="Device Redirection" FontSize="13" FontWeight="Medium" Opacity="0.7" Margin="0,0,0,12" />
                        <CheckBox Content="Clipboard" IsChecked="{Binding RedirectClipboard}" Margin="0,0,0,6" />
                        <CheckBox Content="Printers" IsChecked="{Binding RedirectPrinters}" Margin="0,0,0,6" />
                        <CheckBox Content="Drives" IsChecked="{Binding RedirectDrives}" Margin="0,0,0,6" />
                        <CheckBox Content="Smart Cards" IsChecked="{Binding RedirectSmartCards}" Margin="0,0,0,6" />
                        <CheckBox Content="Ports" IsChecked="{Binding RedirectPorts}" Margin="0,0,0,16" />

                        <TextBlock Text="Audio" FontSize="13" FontWeight="Medium" Opacity="0.7" Margin="0,0,0,12" />
                        <ComboBox materialDesign:HintAssist.Hint="Audio Redirection"
                                  SelectedIndex="{Binding AudioRedirectionMode}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}">
                            <ComboBoxItem Content="Play on this computer" />
                            <ComboBoxItem Content="Play on remote computer" />
                            <ComboBoxItem Content="Do not play" />
                        </ComboBox>
                    </StackPanel>

                    <!-- Connection -->
                    <StackPanel Visibility="{Binding SelectedIndex, ElementName=NavList, Converter={StaticResource IndexToVisibility}, ConverterParameter=4}">
                        <TextBlock Text="Connection" FontSize="18" FontWeight="Medium" Margin="0,0,0,20" />

                        <CheckBox Content="Auto Reconnect" IsChecked="{Binding AutoReconnect}" Margin="0,0,0,6" />
                        <CheckBox Content="Network Level Authentication (NLA)" IsChecked="{Binding NetworkLevelAuthentication}" Margin="0,0,0,6" />
                        <CheckBox Content="Compression" IsChecked="{Binding Compression}" Margin="0,0,0,20" />

                        <TextBlock Text="Gateway" FontSize="13" FontWeight="Medium" Opacity="0.7" Margin="0,0,0,12" />
                        <TextBox materialDesign:HintAssist.Hint="Gateway Host Name"
                                 Text="{Binding GatewayHostName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                    </StackPanel>

                    <!-- Notes -->
                    <StackPanel Visibility="{Binding SelectedIndex, ElementName=NavList, Converter={StaticResource IndexToVisibility}, ConverterParameter=5}">
                        <TextBlock Text="Notes" FontSize="18" FontWeight="Medium" Margin="0,0,0,20" />

                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Height="280"
                                 VerticalContentAlignment="Top" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Footer with buttons -->
        <Border Grid.Row="1"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                Padding="24,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" Style="{StaticResource MaterialDesignFlatMidBgButton}"
                        Click="OkButton_Click" Margin="0,0,8,0" MinWidth="90" />
                <Button Content="Cancel" Style="{StaticResource MaterialDesignFlatButton}"
                        Click="CancelButton_Click" MinWidth="90" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
