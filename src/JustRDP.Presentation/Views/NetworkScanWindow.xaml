<Window x:Class="JustRDP.Presentation.Views.NetworkScanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:JustRDP.Presentation.ViewModels"
        xmlns:converters="clr-namespace:JustRDP.Presentation.Converters"
        Title="Network Scan"
        Height="650" Width="850"
        MinHeight="500" MinWidth="650"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Regular"
        FontFamily="{DynamicResource MaterialDesignFont}"
        d:DataContext="{d:DesignInstance vm:NetworkScanViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Closing="Window_Closing">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:BoolToVisibilityConverter x:Key="InverseBoolToVis" Invert="True" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <converters:NotNullOrEmptyToVisibilityConverter x:Key="NotEmptyToVis" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Scan Parameters -->
        <materialDesign:Card Grid.Row="0" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- CIDR -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="CIDR Range:" VerticalAlignment="Center" Margin="0,0,12,0" />
                <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                         Text="{Binding CidrInput, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="e.g. 192.168.1.0/24"
                         materialDesign:HintAssist.IsFloating="False"
                         IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}"
                         Margin="0,0,0,4" />

                <!-- Range translation -->
                <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                           Text="{Binding RangeTranslation}" FontSize="12" Opacity="0.7"
                           Margin="0,0,0,4"
                           Visibility="{Binding RangeTranslation, Converter={StaticResource NotEmptyToVis}}" />

                <!-- Validation error -->
                <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                           Text="{Binding ValidationError}" FontSize="12" Foreground="#F44336"
                           Margin="0,0,0,4"
                           Visibility="{Binding ValidationError, Converter={StaticResource NotEmptyToVis}}" />

                <!-- Port + Timeout -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Port:" VerticalAlignment="Center" Margin="0,4,12,0" />
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding DefaultPort, UpdateSourceTrigger=PropertyChanged}"
                         Width="80" HorizontalAlignment="Left"
                         IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}"
                         Margin="0,4,0,0" />
                <TextBlock Grid.Row="2" Grid.Column="2" Text="Timeout:" VerticalAlignment="Center" Margin="16,4,12,0" />
                <StackPanel Grid.Row="2" Grid.Column="3" Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBox Text="{Binding TimeoutMs, UpdateSourceTrigger=PropertyChanged}"
                             Width="60"
                             IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}" />
                    <TextBlock Text="ms" VerticalAlignment="Center" Margin="4,0,0,0" Opacity="0.7" />
                </StackPanel>

                <!-- Additional ports -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Additional:" VerticalAlignment="Center" Margin="0,4,12,0" />
                <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                         Text="{Binding AdditionalPorts, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="e.g. 2222;5985;3390"
                         materialDesign:HintAssist.IsFloating="False"
                         IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}"
                         Margin="0,4,0,0" />

                <!-- Port validation error -->
                <TextBlock Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3"
                           Text="{Binding PortValidationError}" FontSize="12" Foreground="#F44336"
                           Margin="0,2,0,0"
                           Visibility="{Binding PortValidationError, Converter={StaticResource NotEmptyToVis}}" />

                <!-- Timeout validation error -->
                <TextBlock Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3"
                           Text="{Binding TimeoutValidationError}" FontSize="12" Foreground="#F44336"
                           Margin="0,2,0,0"
                           Visibility="{Binding TimeoutValidationError, Converter={StaticResource NotEmptyToVis}}" />

                <!-- Security disclaimer -->
                <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,12,0,8">
                    <materialDesign:PackIcon Kind="AlertOutline" Width="16" Height="16" Foreground="#FFC107" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock Text="Network scanning may trigger security alerts. Ensure you have authorization before scanning."
                               FontSize="12" Opacity="0.8" TextWrapping="Wrap" />
                </StackPanel>

                <!-- Buttons + Progress -->
                <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="4">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <Button Content="Start Scan" Command="{Binding StartScanCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}"
                                Padding="16,4" Margin="0,0,8,0">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Play" VerticalAlignment="Center" Margin="0,0,4,0" />
                                        <TextBlock Text="Start Scan" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                        <Button Content="Cancel" Command="{Binding CancelScanCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                IsEnabled="{Binding IsScanning}"
                                Padding="16,4">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Stop" VerticalAlignment="Center" Margin="0,0,4,0" />
                                        <TextBlock Text="Cancel" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                    </StackPanel>
                    <Grid Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                        <ProgressBar Value="{Binding Progress}" Maximum="{Binding ProgressMax}"
                                     Height="8" Margin="0,0,0,4" />
                    </Grid>
                    <TextBlock Text="{Binding ProgressText}" FontSize="12" Opacity="0.7"
                               HorizontalAlignment="Center"
                               Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- Results Header -->
        <DockPanel Grid.Row="1" Margin="0,0,0,4">
            <Button DockPanel.Dock="Right" Content="Select All New"
                    Command="{Binding SelectAllNewCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Padding="8,2" Height="28"
                    Visibility="{Binding HasScanRun, Converter={StaticResource BoolToVis}}" />
            <TextBlock Text="{Binding ResultsHeader}" FontSize="14" FontWeight="Medium"
                       VerticalAlignment="Center" />
        </DockPanel>

        <!-- Results DataGrid -->
        <Grid Grid.Row="2">
            <!-- Placeholder: before first scan -->
            <TextBlock Text="Run a scan to discover hosts on your network"
                       Opacity="0.4" FontSize="14"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Visibility="{Binding HasScanRun, Converter={StaticResource InverseBoolToVis}}" />

            <DataGrid ItemsSource="{Binding Results}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      IsReadOnly="False"
                      SelectionMode="Single"
                      CanUserSortColumns="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="1"
                      BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                      Visibility="{Binding HasScanRun, Converter={StaticResource BoolToVis}}">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ExistsInDatabase}" Value="True">
                                <Setter Property="Background" Value="#224CAF50" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ExistsInDatabase}" Value="False">
                                <Setter Property="Background" Value="#222196F3" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="40" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding CanCheck}"
                                          HorizontalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="IP Address" Binding="{Binding IpAddress}" Width="140" IsReadOnly="True" />
                    <DataGridTextColumn Header="Hostname" Binding="{Binding HostName}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="Protocol" Binding="{Binding ProtocolDisplay}" Width="70" IsReadOnly="True" />
                    <DataGridTextColumn Header="Port" Binding="{Binding SelectedPort}" Width="60" IsReadOnly="True" />
                    <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="70" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Bottom Bar: Folder selection + Import -->
        <Grid Grid.Row="3" Margin="0,8,0,0"
              Visibility="{Binding HasScanRun, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Import to:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox Grid.Column="1" ItemsSource="{Binding TargetFolders}"
                      SelectedItem="{Binding SelectedFolder}"
                      MinWidth="180" MaxWidth="300"
                      materialDesign:HintAssist.IsFloating="False"
                      VerticalAlignment="Center" />
            <Button Grid.Column="2" Command="{Binding ImportSelectedCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Padding="16,4" Margin="8,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Import" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="Import Selected (" /><Run Text="{Binding SelectedCount, Mode=OneWay}" /><Run Text=")" />
                    </TextBlock>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
