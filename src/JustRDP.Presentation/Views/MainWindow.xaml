<Window x:Class="JustRDP.Presentation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:JustRDP.Presentation.ViewModels"
        xmlns:converters="clr-namespace:JustRDP.Presentation.Converters"
        xmlns:behaviors="clr-namespace:JustRDP.Presentation.Behaviors"
        xmlns:views="clr-namespace:JustRDP.Presentation.Views"
        mc:Ignorable="d"
        Title="JustRDP"
        Icon="/app.ico"
        Height="700" Width="1200"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Regular"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{DynamicResource MaterialDesignFont}"
        x:Name="ThisWindow"
        d:DataContext="{d:DesignInstance vm:MainWindowViewModel}"
        Loaded="MainWindow_OnLoaded">

    <Window.Resources>
        <converters:TreeEntryTypeToIconConverter x:Key="EntryTypeToIcon" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:BoolToVisibilityConverter x:Key="InverseBoolToVis" Invert="True" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <converters:AvailabilityStatusToBrushConverter x:Key="AvailabilityToBrush" />

        <DataTemplate x:Key="RdpTabTemplate"><views:ConnectionTabView /></DataTemplate>
        <DataTemplate x:Key="SshTabTemplate"><views:SshTabView /></DataTemplate>
        <views:ConnectionTabTemplateSelector x:Key="TabTemplateSelector"
            RdpTemplate="{StaticResource RdpTabTemplate}"
            SshTemplate="{StaticResource SshTabTemplate}" />
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddConnectionCommand}" />
        <KeyBinding Key="N" Modifiers="Ctrl+Shift" Command="{Binding AddFolderCommand}" />
        <KeyBinding Key="F2" Command="{Binding RenameSelectedCommand}" />
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}" />
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseActiveTabCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <materialDesign:ColorZone Grid.Row="0" Mode="PrimaryMid" Padding="6,4">
            <DockPanel>
                <!-- Right: settings -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="8,0,0,0">
                    <Button Style="{StaticResource MaterialDesignToolForegroundButton}"
                            ToolTip="Open Log Folder"
                            Command="{Binding OpenLogFolderCommand}"
                            Padding="8,4" Height="32">
                        <materialDesign:PackIcon Kind="FolderFileOutline" />
                    </Button>
                    <Button Style="{StaticResource MaterialDesignToolForegroundButton}"
                            ToolTip="Toggle Theme"
                            Command="{Binding ToggleThemeCommand}"
                            Padding="8,4" Height="32">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ThemeLightDark" VerticalAlignment="Center" />
                            <TextBlock Text="Theme" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignToolForegroundButton}"
                            ToolTip="About"
                            Command="{Binding ShowAboutCommand}"
                            Padding="8,4" Height="32">
                        <materialDesign:PackIcon Kind="InformationOutline" />
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <!-- Create group -->
                    <Button Style="{StaticResource MaterialDesignToolForegroundButton}"
                            ToolTip="New Folder (Ctrl+Shift+N)"
                            Command="{Binding AddFolderCommand}"
                            Padding="8,4" Height="32">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FolderPlus" VerticalAlignment="Center" />
                            <TextBlock Text="New Folder" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatMidBgButton}"
                            ToolTip="New Connection (Ctrl+N)"
                            Command="{Binding AddConnectionCommand}"
                            Margin="4,0,0,0" Padding="12,4"
                            Height="32">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="MonitorDashboard" VerticalAlignment="Center" />
                            <TextBlock Text="New Connection" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Separator Style="{StaticResource MaterialDesignSeparator}" Margin="10,4" />

                    <!-- Data I/O group -->
                    <Button Style="{StaticResource MaterialDesignToolForegroundButton}"
                            ToolTip="Import"
                            Command="{Binding ImportCommand}"
                            Padding="8,4" Height="32">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Import" VerticalAlignment="Center" />
                            <TextBlock Text="Import" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignToolForegroundButton}"
                            ToolTip="Export"
                            Command="{Binding ExportCommand}"
                            Padding="8,4" Height="32">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Export" VerticalAlignment="Center" />
                            <TextBlock Text="Export" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Separator Style="{StaticResource MaterialDesignSeparator}" Margin="10,4" />

                    <!-- Quick Connect -->
                    <TextBox x:Name="QuickConnectBox"
                             Width="200" Height="28"
                             VerticalAlignment="Center"
                             Margin="4,0,4,0" Padding="4,2"
                             FontSize="13"
                             materialDesign:HintAssist.Hint="Quick Connect (host:port or ssh://user@host)"
                             materialDesign:HintAssist.IsFloating="False"
                             materialDesign:TextFieldAssist.HasClearButton="True"
                             materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                             Background="{DynamicResource MaterialDesign.Brush.Background}"
                             Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                             Text="{Binding QuickConnectAddress, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="QuickConnectBox_KeyDown" />
                    <Button Style="{StaticResource MaterialDesignToolForegroundButton}"
                            ToolTip="Connect"
                            Command="{Binding QuickConnectCommand}"
                            Padding="8,4" Height="32">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Play" VerticalAlignment="Center" />
                            <TextBlock Text="Connect" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Separator Style="{StaticResource MaterialDesignSeparator}" Margin="10,4" />

                    <!-- Network Scan -->
                    <Button Style="{StaticResource MaterialDesignToolForegroundButton}"
                            ToolTip="Scan Network"
                            Command="{Binding ShowScanCommand}"
                            Padding="8,4" Height="32">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Radar" VerticalAlignment="Center" />
                            <TextBlock Text="Scan" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Availability Monitor -->
                    <ToggleButton Style="{StaticResource MaterialDesignToolForegroundButton}"
                                  ToolTip="Toggle Availability Monitor"
                                  IsChecked="{Binding IsMonitoringEnabled}"
                                  Command="{Binding ToggleMonitoringCommand}"
                                  Padding="8,4" Height="32">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="HeartPulse" VerticalAlignment="Center" />
                            <TextBlock Text="Monitor" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </ToggleButton>
                </StackPanel>
            </DockPanel>
        </materialDesign:ColorZone>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TreeColumn" Width="250" MinWidth="150" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Tree View Panel -->
            <Border Grid.Column="0" BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}">
                <DockPanel>
                    <!-- Search filter + Connect Selected bar -->
                    <DockPanel DockPanel.Dock="Top" Margin="4,4,4,0">
                        <Button DockPanel.Dock="Right"
                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                ToolTip="Connect Selected"
                                Command="{Binding ConnectSelectedCommand}"
                                Visibility="{Binding HasCheckedEntries, Converter={StaticResource BoolToVis}}"
                                Width="28" Height="28">
                            <materialDesign:PackIcon Kind="PlayCircleOutline" Width="20" Height="20" />
                        </Button>
                        <TextBox materialDesign:HintAssist.Hint="Filter..."
                                 materialDesign:HintAssist.IsFloating="False"
                                 materialDesign:TextFieldAssist.HasClearButton="True"
                                 materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                 FontSize="13" Padding="4,2"
                                 Text="{Binding TreeFilterText, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>

                    <Grid>
                        <TextBlock Text="No entries yet.&#x0a;Use the toolbar to create a folder or connection."
                                   TextWrapping="Wrap" Margin="16"
                                   Opacity="0.5" TextAlignment="Center"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Visibility="{Binding TreeVM.HasEntries, Converter={StaticResource InverseBoolToVis}}" />

                        <TreeView ItemsSource="{Binding TreeVM.FilteredRootEntries}"
                                  Visibility="{Binding TreeVM.HasEntries, Converter={StaticResource BoolToVis}}"
                                  behaviors:TreeViewDragDropBehavior.IsEnabled="True"
                                  behaviors:TreeViewDragDropBehavior.TreeViewModel="{Binding TreeVM}"
                                  VirtualizingStackPanel.IsVirtualizing="True"
                                  BorderThickness="0" Padding="4"
                                  SelectedItemChanged="TreeView_SelectedItemChanged"
                                  KeyDown="TreeView_KeyDown">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem" BasedOn="{StaticResource MaterialDesignTreeViewItem}">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                    <Setter Property="Padding" Value="4,1" />
                                    <Setter Property="MinHeight" Value="24" />
                                    <EventSetter Event="MouseDoubleClick" Handler="TreeViewItem_MouseDoubleClick" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding FilteredChildren}">
                                    <Grid>
                                        <!-- Normal display -->
                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
                                            <CheckBox IsChecked="{Binding IsChecked}"
                                                      VerticalAlignment="Center" Margin="0,0,4,0"
                                                      Visibility="{Binding ShowCheckBox, Converter={StaticResource BoolToVis}}" />
                                            <Ellipse Width="8" Height="8" Margin="0,0,4,0"
                                                     VerticalAlignment="Center"
                                                     Fill="{Binding AvailabilityStatus, Converter={StaticResource AvailabilityToBrush}}">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DataContext.IsMonitoringEnabled, Source={x:Reference ThisWindow}}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ShowAvailabilityDot}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <materialDesign:PackIcon VerticalAlignment="Center" Margin="0,0,6,0" Width="18" Height="18">
                                                <materialDesign:PackIcon.Kind>
                                                    <MultiBinding Converter="{StaticResource EntryTypeToIcon}">
                                                        <Binding Path="EntryType" />
                                                        <Binding Path="ConnectionType" />
                                                        <Binding Path="IsDashboard" />
                                                    </MultiBinding>
                                                </materialDesign:PackIcon.Kind>
                                            </materialDesign:PackIcon>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <!-- Inline edit mode -->
                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                            <materialDesign:PackIcon VerticalAlignment="Center" Margin="0,0,6,0" Width="18" Height="18">
                                                <materialDesign:PackIcon.Kind>
                                                    <MultiBinding Converter="{StaticResource EntryTypeToIcon}">
                                                        <Binding Path="EntryType" />
                                                        <Binding Path="ConnectionType" />
                                                        <Binding Path="IsDashboard" />
                                                    </MultiBinding>
                                                </materialDesign:PackIcon.Kind>
                                            </materialDesign:PackIcon>
                                            <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                                     MinWidth="120" Padding="2"
                                                     materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                                     Loaded="EditTextBox_Loaded"
                                                     LostFocus="EditTextBox_LostFocus"
                                                     KeyDown="EditTextBox_KeyDown" />
                                        </StackPanel>
                                    </Grid>

                                <!-- Context Menu -->
                                <HierarchicalDataTemplate.Resources>
                                    <Style TargetType="Grid">
                                        <Setter Property="ContextMenu">
                                            <Setter.Value>
                                                <ContextMenu>
                                                    <MenuItem Header="Connect All"
                                                              Command="{Binding DataContext.TreeVM.ConnectAllCommand, Source={x:Reference ThisWindow}}"
                                                              CommandParameter="{Binding}"
                                                              Icon="{materialDesign:PackIcon Kind=PlayCircleOutline}"
                                                              Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}}" />
                                                    <MenuItem Header="Sort Alphabetically"
                                                              Command="{Binding DataContext.TreeVM.SortChildrenCommand, Source={x:Reference ThisWindow}}"
                                                              CommandParameter="{Binding}"
                                                              Icon="{materialDesign:PackIcon Kind=SortAlphabeticalAscending}"
                                                              Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}}" />
                                                    <Separator Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}}" />
                                                    <MenuItem Header="New Folder"
                                                              Command="{Binding DataContext.TreeVM.AddFolderCommand, Source={x:Reference ThisWindow}}"
                                                              CommandParameter="{Binding Id}"
                                                              Icon="{materialDesign:PackIcon Kind=FolderPlus}" />
                                                    <MenuItem Header="New Connection"
                                                              Command="{Binding DataContext.TreeVM.AddConnectionCommand, Source={x:Reference ThisWindow}}"
                                                              CommandParameter="{Binding Id}"
                                                              Icon="{materialDesign:PackIcon Kind=MonitorDashboard}" />
                                                    <Separator />
                                                    <MenuItem Header="Duplicate Connection"
                                                              Command="{Binding DataContext.TreeVM.DuplicateConnectionCommand, Source={x:Reference ThisWindow}}"
                                                              CommandParameter="{Binding}"
                                                              Icon="{materialDesign:PackIcon Kind=ContentDuplicate}"
                                                              Visibility="{Binding IsConnection, Converter={StaticResource BoolToVis}}" />
                                                    <Separator Visibility="{Binding IsConnection, Converter={StaticResource BoolToVis}}" />
                                                    <MenuItem Header="Rename (F2)"
                                                              Command="{Binding BeginEditCommand}"
                                                              Icon="{materialDesign:PackIcon Kind=Pencil}" />
                                                    <MenuItem Header="Delete"
                                                              Command="{Binding DataContext.TreeVM.DeleteEntryCommand, Source={x:Reference ThisWindow}}"
                                                              CommandParameter="{Binding}"
                                                              Icon="{materialDesign:PackIcon Kind=Delete}" />
                                                    <Separator />
                                                    <MenuItem Header="Properties"
                                                              Command="{Binding DataContext.OpenPropertiesDialogCommand, Source={x:Reference ThisWindow}}"
                                                              Icon="{materialDesign:PackIcon Kind=CogOutline}" />
                                                </ContextMenu>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDashboard}" Value="True">
                                                <Setter Property="ContextMenu" Value="{x:Null}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </HierarchicalDataTemplate.Resources>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                    </Grid>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent" />

            <!-- Tab Area -->
            <Grid Grid.Column="2">
                <!-- Dashboard (visible when no tab selected or Dashboard node clicked) -->
                <views:DashboardView DataContext="{Binding DashboardVM}"
                                     Visibility="{Binding IsDashboardVisible, Converter={StaticResource BoolToVis}}" />

                <!-- Tabs (visible when a connection tab is active) -->
                <DockPanel Visibility="{Binding IsDashboardVisible, Converter={StaticResource InverseBoolToVis}}">
                    <!-- Tab headers only (no content area) -->
                    <TabControl DockPanel.Dock="Top"
                                ItemsSource="{Binding OpenTabs}"
                                SelectedItem="{Binding SelectedTab}"
                                BorderThickness="0">
                        <TabControl.ItemContainerStyle>
                            <Style TargetType="TabItem" BasedOn="{StaticResource MaterialDesignTabItem}">
                                <Setter Property="Padding" Value="8,2" />
                                <Setter Property="Height" Value="28" />
                            </Style>
                        </TabControl.ItemContainerStyle>
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding TabTitle}" VerticalAlignment="Center" FontSize="12" />
                                    <Button ToolTip="Close Tab (Ctrl+W)"
                                            Command="{Binding DataContext.CloseTabCommand, Source={x:Reference ThisWindow}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignToolForegroundButton}"
                                            Padding="0" Margin="6,0,0,0"
                                            Width="16" Height="16">
                                        <materialDesign:PackIcon Kind="Close" Width="12" Height="12" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <!-- Empty content — real content is in the ItemsControl below -->
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <Border />
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>

                    <!-- All RDP views live here simultaneously; only the selected one is Visible.
                         Collapsed WindowsFormsHost properly hides the native HWND (airspace fix). -->
                    <ItemsControl ItemsSource="{Binding OpenTabs}"
                                  ItemTemplateSelector="{StaticResource TabTemplateSelector}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Grid />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                </DockPanel>
            </Grid>

        </Grid>

        <!-- Status Bar -->
        <materialDesign:ColorZone Grid.Row="2" Mode="PrimaryDark" Padding="8,4">
            <TextBlock Text="{Binding StatusText}" FontSize="12" />
        </materialDesign:ColorZone>
    </Grid>
</Window>
